{
    "buildCommand": "",
    "outputDirectory": ".",
    "rewrites": [
        {
            "source": "/politica-de-privacidade",
            "destination": "/politica-de-privacidade.html"
        },
        {
            "source": "/privacidade",
            "destination": "/politica-de-privacidade.html"
        },
        {
            "source": "/excluir-conta",
            "destination": "/excluir-conta.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "0"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(), microphone=(), geolocation=()"
                },
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self'; script-src 'self'; script-src-attr 'none'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'none'; upgrade-insecure-requests"
                },
                {
                    "key": "Strict-Transport-Security",
                    "value": "max-age=31536000"
                }
            ]
        }
    ]
}
